#!/usr/bin/env bash

DATA_DIR="${DATA_DIR:-$HOME/Documents/Personal/Tracker}"
LIBRARY_JSON="$DATA_DIR/library.json"
MEDIA_DIR="$DATA_DIR/media"
BACKUP_DIR="$DATA_DIR/backups"

# Create backups directory if it doesn't exist
mkdir -p "$BACKUP_DIR"

# 1️⃣ Create timestamped backup
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_JSON="$BACKUP_DIR/library_$TIMESTAMP.json.bak"
cp "$LIBRARY_JSON" "$BACKUP_JSON"
echo "Backup created: $BACKUP_JSON"

EXIT=false
while ! $EXIT; do
    # --- Select type ---
    TYPES=$(jq -r '.media[].type' "$LIBRARY_JSON" | sort -u)
    if [[ -z "$TYPES" ]]; then
        echo "No media types found in library."
        break
    fi

    TYPE=$(echo "$TYPES" | fzf --prompt="Select type to update (q to quit): ")
    if [[ "$TYPE" == "~" ]]; then
        break
    elif [[ "$TYPE" == "q" || -z "$TYPE" ]]; then
        echo "No type selected. Exiting."
        break
    fi

    # --- Check for titles of this type ---
    TITLES=$(jq -r --arg TYPE "$TYPE" '.media[] | select(.type==$TYPE) | .title' "$LIBRARY_JSON")
    if [[ -z "$TITLES" ]]; then
        echo "No items of type '$TYPE' found."
        sleep 0.5
        continue
    fi

    # --- Title selection loop ---
    while true; do
        TITLE=$(echo "$TITLES" | fzf --prompt="Select $TYPE to edit (q to go back, ~ to quit): ")
        if [[ "$TITLE" == "~" ]]; then
            EXIT=true
            break 2
        elif [[ "$TITLE" == "q" || -z "$TITLE" ]]; then
            break
        fi

        # --- Select Item Data ---
        ID=$(jq -r --arg TITLE "$TITLE" --arg TYPE "$TYPE" '.media[] | select(.title==$TITLE and .type==$TYPE) | .id' "$LIBRARY_JSON")
        SAFE_ID="${ID//[:\/]/_}"
        MEDIA_FILE="$MEDIA_DIR/${SAFE_ID}.json"
        
        if [[ -f "$MEDIA_FILE" ]]; then
            ITEM=$(cat "$MEDIA_FILE")
        else
            ITEM=$(jq -r --arg TITLE "$TITLE" --arg TYPE "$TYPE" '.media[] | select(.title==$TITLE and .type==$TYPE)' "$LIBRARY_JSON")
        fi

        STATUS=$(echo "$ITEM" | jq -r '.status // ""')
        CURRENT=$(echo "$ITEM" | jq -r '.progress.current // 0')
        TOTAL=$(echo "$ITEM" | jq -r '.progress.total // 0')
        UNIT=$(echo "$ITEM" | jq -r '.progress.unit // "episode"')

        if [[ "$TYPE" == "tv" || "$TYPE" == "anime" ]]; then
            SEASONS_CURRENT=$(echo "$ITEM" | jq -r '.seasons.current // 0')
            SEASONS_TOTAL=$(echo "$ITEM" | jq -r '.seasons.total // 0')
        fi

        # --- Edit prompts ---
        echo "Updating: $TITLE ($TYPE)"
        read -p "Status [$STATUS]: " NEW_STATUS
        NEW_STATUS=${NEW_STATUS:-$STATUS}
        read -p "Current $UNIT [$CURRENT]: " NEW_CURRENT
        NEW_CURRENT=${NEW_CURRENT:-$CURRENT}
        read -p "Total $UNIT [$TOTAL]: " NEW_TOTAL
        NEW_TOTAL=${NEW_TOTAL:-$TOTAL}

        if [[ "$TYPE" == "tv" || "$TYPE" == "anime" ]]; then
            read -p "Season Current [$SEASONS_CURRENT]: " NEW_SEASONS_CURRENT
            NEW_SEASONS_CURRENT=${NEW_SEASONS_CURRENT:-$SEASONS_CURRENT}
            read -p "Season Total [$SEASONS_TOTAL]: " NEW_SEASONS_TOTAL
            NEW_SEASONS_TOTAL=${NEW_SEASONS_TOTAL:-$SEASONS_TOTAL}
        fi

        # --- Sync userEpisodes if it is a multi-episode content ---
        if [[ "$TYPE" == "tv" || "$TYPE" == "anime" ]]; then
            # If current progress increased, mark all episodes up to New_Current as watched
            # Use jq to update the sidecar's userEpisodes map
            ITEM=$(echo "$ITEM" | jq --argjson new_curr "$NEW_CURRENT" --argjson old_curr "$CURRENT" \
                'if $new_curr > $old_curr then
                    reduce range(1; ($new_curr | tonumber) + 1) as $i (.;
                        .userEpisodes["0_\($i)"] |= (if . == null then {number: $i, season: 0, watched: true} else .watched = true end)
                    )
                 else . end')
        fi

        # --- Update fields ---
        UPDATED_ITEM=$(echo "$ITEM" | jq --arg STATUS "$NEW_STATUS" \
            --argjson CURRENT "$NEW_CURRENT" \
            --argjson TOTAL "$NEW_TOTAL" \
            --argjson SEASONS_CURRENT "${NEW_SEASONS_CURRENT:-0}" \
            --argjson SEASONS_TOTAL "${NEW_SEASONS_TOTAL:-0}" \
            '.status = $STATUS |
             .progress.current = $CURRENT |
             .progress.total = $TOTAL |
             if .type=="tv" or .type=="anime" then
                .seasons.current = $SEASONS_CURRENT |
                .seasons.total = $SEASONS_TOTAL
             else . end |
             .timestamps.updated = (date +%FT%T%Z)')
        
        echo "$UPDATED_ITEM" > "$MEDIA_FILE"

        # --- Update minimal library index ---
        MINIMAL_ITEM=$(echo "$UPDATED_ITEM" | jq -c '
          {
            id: .id,
            title: .title,
            type: .type,
            status: .status,
            progress: .progress,
            poster_path: .poster_path,
            local: .local,
            rating: (.rating // .vote_average // 0),
            brand: (.brand // ""),
            metadata: { 
              year: (.metadata.year // null), 
              release_date: (.metadata.release_date // null)
            },
            source: .source,
            file: ("media/" + ($id | gsub("[:/]"; "_")) + ".json")
          }
        ' --arg id "$ID")

        tmp=$(mktemp)
        jq --arg id "$ID" --argjson NEW_ITEM "$MINIMAL_ITEM" \
           '(.media[] | select(.id==$id)) |= $NEW_ITEM' \
           "$LIBRARY_JSON" > "$tmp" && mv "$tmp" "$LIBRARY_JSON"

        echo "✅ Updated $TITLE"
        sleep 0.2
    done
done

echo "Exited mt-update."

# --- Remove oldest backups, keep only last 10 ---
echo "Cleaning old backups, keeping only 10 latest..."
ls -1t "$BACKUP_DIR"/library_*.json.bak | tail -n +11 | xargs -r rm
echo "Done."
