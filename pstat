#!/bin/bash
# --- HELP UTILITY START ---
show_help() {
    cat << HELP_EOF
Usage: ${0##*/} [FILE...]

Description:
    Examining the physical and cognitive manifestations of files.
    A Radiant's tool for deep inspection of objects in the Realm.

Options:
    -h, --help    Display this help message and exit.

HELP_EOF
}
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi
# --- HELP UTILITY END ---

# --- Radiant Theme Colors ---
STORMLIGHT='\033[0;36m' 
HONOR='\033[0;33m'      
SYL='\033[0;37m'        
VOID='\033[0;35m'       
NC='\033[0m'            

human_size() {
    local bytes=$1
    if [[ $bytes -lt 1024 ]]; then
        echo "${bytes} B"
    elif [[ $bytes -lt 1048576 ]]; then
        echo "$(bc <<< "scale=2; $bytes/1024") KB"
    elif [[ $bytes -lt 1073741824 ]]; then
        echo "$(bc <<< "scale=2; $bytes/1048576") MB"
    else
        echo "$(bc <<< "scale=2; $bytes/1073741824") GB"
    fi
}

for arg in "$@"; do
    echo -e "${STORMLIGHT}--------------------------------------------${NC}"
    echo -e "${HONOR}󱐌 PHYSICAL MANIFESTATION:${NC} ${SYL}$arg${NC}"
    echo -e "${STORMLIGHT}--------------------------------------------${NC}"
    
    if [ -d "$arg" ]; then
        # FOLDER SPECIFIC
        /usr/bin/stat -f "Type:       %HT
Permissions: %Sp (%Lp)
Owner:       %Su/%Sg
Created:     %SB
Modified:    %Sm" "$arg"
        
        SIZE=$(du -sh "$arg" | cut -f1)
        echo -e "Total Size:  $SIZE (Recursive)"
    else
        # FILE SPECIFIC
        RAW_BYTES=$(/usr/bin/stat -f "%z" "$arg")
        H_SIZE=$(human_size $RAW_BYTES)

        /usr/bin/stat -f "Type:       %HT
Permissions: %Sp (%Lp)" "$arg"
        echo -e "Size:        $H_SIZE ($RAW_BYTES bytes)"
        /usr/bin/stat -f "Owner:       %Su/%Sg
Created:     %SB
Modified:    %Sm
Accessed:    %Sa" "$arg"
        
        # Media metadata check
        ext="${arg##*.}"
        if [[ "$ext" =~ ^(png|jpg|jpeg|mp4|mov|pdf|m4b|mkv|mp3)$ ]]; then
            echo -e "${STORMLIGHT}--------------------------------------------${NC}"
            echo -e "${HONOR}💿 COGNITIVE ESSENCE (Media Metadata):${NC}"
            mdls -name kMDItemPixelWidth -name kMDItemPixelHeight -name kMDItemDuration "$arg" 2>/dev/null
        fi
    fi
    echo -e "${STORMLIGHT}--------------------------------------------${NC}"
done
